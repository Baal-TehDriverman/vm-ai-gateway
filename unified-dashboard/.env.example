# Lilith Unified Dashboard - Environment Configuration
# Copy this file to .env and fill in your values

# ===== GEMINI AI =====
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ===== GITHUB API =====
# Create a Personal Access Token at: https://github.com/settings/tokens
# Required scopes: repo, read:user, read:org
GITHUB_TOKEN=

# ===== LILITH GATEWAY =====
# Gateway runs on port 8080
LILITH_GATEWAY_URL=http://localhost:8080
GATEWAY_AUTH_TOKEN=

# ===== OLLAMA =====
# Local Ollama runs on port 11434
OLLAMA_URL=http://localhost:11434

# ===== SERVER =====
PORT=3000
NODE_ENV=development

# ===== OBSIDIAN VAULT =====
OBSIDIAN_VAULT_PATH=/home/tehlappy/Documents/Obsidian Vault

# ===== KAIROS DREAM =====
KAIROS_SCRIPT_PATH=/home/tehlappy/Projects/Dev Console/kairos_clean.py